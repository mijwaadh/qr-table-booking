datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider             = "prisma-client-py"
  recursive_type_depth = 5
  enable_experimental_decimal = true
}

model MarketPrice {
  id           String   @id @default(uuid()) @db.VarChar(36)
  commodity    String   @db.VarChar(255)
  variety      String   @db.VarChar(255)
  state        String   @db.VarChar(100)
  district     String   @db.VarChar(100)
  market       String   @db.VarChar(255)
  arrivalDate  DateTime @map("arrival_date") @db.Date
  minPrice     Decimal  @map("min_price") @db.Decimal(12, 2)
  maxPrice     Decimal  @map("max_price") @db.Decimal(12, 2)
  modalPrice   Decimal  @map("modal_price") @db.Decimal(12, 2)
  pricePerKg   Decimal  @map("price_per_kg") @db.Decimal(12, 2)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamp(3)

  @@index([commodity])
  @@index([state])
  @@index([district])
  @@index([arrivalDate])
  @@map("market_prices")
}

model MarketPrediction {
  id             String   @id @default(uuid()) @db.VarChar(36)
  commodity      String   @db.VarChar(255)
  variety        String   @db.VarChar(255)
  market         String   @db.VarChar(255)
  predictionDate DateTime @map("prediction_date") @db.Date
  forecastDate   DateTime @map("forecast_date") @db.Date
  forecastPrice  Decimal  @map("forecast_price") @db.Decimal(12, 2)
  lowerBound     Decimal  @map("lower_bound") @db.Decimal(12, 2)
  upperBound     Decimal  @map("upper_bound") @db.Decimal(12, 2)
  horizonDays    Int      @map("horizon_days")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamp(3)

  @@index([commodity])
  @@index([forecastDate])
  @@map("market_predictions")
}
